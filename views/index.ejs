<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Huddle Challenge 8 - Ranking de Temas</title>
    <style>
        :root { --primary: #2563eb; --bg: #f8fafc; --text: #1e293b; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        .container { max-width: 800px; margin: 0 auto; }
        h1 { text-align: center; color: var(--primary); }
        
        .card { 
            background: white; padding: 20px; border-radius: 12px; 
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin-bottom: 15px;
            display: flex; justify-content: space-between; align-items: center;
            transition: transform 0.2s;
        }
        .card:hover { transform: translateY(-2px); }
        .info { flex-grow: 1; }
        .info h3 { margin: 0 0 8px 0; color: #000; }
        .info p { margin: 0; font-size: 0.9em; color: #64748b; }
        
        .votos-badge {
            background: #dbeafe; color: var(--primary); font-weight: bold;
            padding: 8px 12px; border-radius: 20px; margin-right: 15px;
            min-width: 80px; text-align: center;
        }

        .btn-votar {
            background-color: var(--primary); color: white; border: none;
            padding: 10px 20px; border-radius: 8px; cursor: pointer;
            font-weight: 600; transition: background 0.3s;
        }
        .btn-votar:hover { background-color: #1d4ed8; }
        .btn-votar:active { transform: scale(0.95); }

        .total-footer { text-align: center; margin-top: 30px; font-weight: bold; color: #64748b; }
    </style>
</head>
<body>

    <div class="container">
        <h1>🚀 Temas para Aprender</h1>

        <div id="lista-temas">
            <% if (temas.length > 0) { %>
                <% temas.forEach((tema, index) => { %>
                    <div class="card">
                        <div class="votos-badge">
                            🔥 <%= tema.votos_tema %>
                        </div>
                        
                        <div class="info">
                            <h3><%= tema.nombre_tema %></h3>
                            <p><%= tema.descripcion_tema %></p>
                            <small>Sugerido por: <strong><%= tema.autor_tema %></strong></small>
                        </div>

                        <button class="btn-votar" onclick="votar(<%= tema.id_tema %>)">
                            Votar
                        </button>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align: center;">No hay temas creados todavía. ¡Usa Postman para crear el primero!</p>
            <% } %>
        </div>

        <div class="total-footer">
            Total de temas en el sistema: <%= total_temas %>
        </div>
    </div>

    <script src="/js/script.js"></script>

    <script>
        async function votar(id_tema) {
            try {
                // Simulamos un ID de usuario para el Challenge
                const id_usuario = Math.floor(Math.random() * 1000); 

                const response = await fetch(`/temas/${id_tema}/votos`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id_usuario })
                });

                if (response.ok) {
                    // Recargamos para que el backend reordene por votos
                    window.location.reload();
                } else {
                    alert("Error al registrar el voto");
                }
            } catch (err) {
                console.error("Error:", err);
            }
        }
    </script>
</body>
</html>